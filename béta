<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <title>Magyar Forint Katalógus</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="header">
        <div class="stats-grid">
            <div><span class="stat-val" id="total-count">0</span>Összes</div>
            <div><span class="stat-val" id="collected-count">0</span>Megvan</div>
            <div><span class="stat-val" id="percent">0%</span>Kész</div>
        </div>
    </div>

    <div class="search-container" style="padding: 10px; max-width: 600px; margin: 0 auto;">
        <input type="text" id="coin-search" placeholder="Keress bárhol (év, név, forint...)" 
               onkeyup="filterCoins()" 
               style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ccc; font-size: 16px; box-sizing: border-box;">
    </div>

    <div id="main-menu">
        <div class="menu-card" onclick="openCatalog('forint92')">💰 Modern Forintok (1992-)</div>
        <div class="menu-card" onclick="openCatalog('emlek')">🏆 Emlékveretek</div>
        <div class="menu-card" onclick="openCatalog('nepkoztarsasag')">⌛ Régi pénzek</div>
    </div>

    <div id="catalog-view" style="display: none;">
        <button class="back-btn" onclick="showMenu()">← Vissza a főmenühöz</button>
        <div id="catalog-container"></div>
    </div>

    <div id="image-overlay" onclick="this.style.display='none'">
        <img id="zoomed-img" src="" alt="Nagy kép">
    </div>

    <script src="forint92.js"></script>
    <script src="emlek.js"></script>
    <script src="nepkoztarsasag.js"></script>
<script>
    // 1. Adatbázis inicializálása
    if (typeof databases === 'undefined') { 
        var databases = {}; 
    }

    

     

    // --- FUNKCIÓK ---

    function openCatalog(catId) {
    const container = document.getElementById('catalog-container');
    container.dataset.activeCat = catId; 
    container.innerHTML = '';
    
    if (!databases[catId] || databases[catId].length === 0) {
        container.innerHTML = '<p style="text-align:center; padding:20px;">Hamarosan feltöltve...</p>';
    } else {
        databases[catId].forEach(group => {
            let html = `<div class="coin-group" id="group-${group.id}">
                <div class="group-header" onclick="toggleGroup('${group.id}')">
                    <span>${group.name}</span>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <span class="group-percent" id="perc-${group.id}" style="font-size: 0.8em; opacity: 0.8;">0%</span>
                        <span class="group-progress" id="prog-${group.id}">0/0</span> 
                        <span class="arrow">▼</span>
                    </div>
                </div>
                <div class="year-list" id="list-${group.id}" style="display:none;">`; 
            
            group.years.forEach(item => {
                const storageKey = `coin-${group.id}-${item.y}`;
                const checked = localStorage.getItem(storageKey) === 'true';
                const imgTag = item.img ? `<img src="${item.img}" class="coin-thumb" onclick="zoomImg('${item.img}', event)">` : '';
                
                html += `
    <div class="year-row ${checked ? 'is-collected' : ''}" id="row-${group.id}-${item.y}">
        ${imgTag}
        <div class="year-info">
            <strong>${item.y}</strong> - <span class="coin-name-top">${item.n}</span>
            
            <div class="coin-details-sub">
                <span class="coin-material">Anyag: ${item.a}</span>
                <span class="mintage">Veremszám: ${item.m}</span>
            </div>
        </div>
        <input type="checkbox" data-group="${group.id}" ${checked ? 'checked' : ''} onchange="updateCoin('${group.id}', '${item.y}', this.checked)">
    </div>`;
            });
            container.innerHTML += html + `</div></div>`;
        });
    }
    document.getElementById('main-menu').style.display = 'none';
    document.getElementById('catalog-view').style.display = 'block';
    
    // FONTOS: Belépéskor azonnal futtatjuk a szűrést az aktuális keresőszóra
    filterCoins(); 
    refreshStats();
}

function filterCoins() {
    const val = document.getElementById('coin-search').value.toLowerCase().trim();
    const isMainMenu = document.getElementById('main-menu').style.display !== 'none';

    // 1. FŐMENÜ SZŰRÉSE
    const menuCards = document.querySelectorAll('.menu-card');
    menuCards.forEach(card => {
        const onclickAttr = card.getAttribute('onclick') || "";
        const match = onclickAttr.match(/'([^']+)'/);
        if (!match) return;
        
        const catId = match[1];
        const db = databases[catId] || [];

        const cardNameMatches = card.innerText.toLowerCase().includes(val);
        const dbHasMatch = db.some(group => 
            group.name.toLowerCase().includes(val) || 
            group.years.some(y => y.y.toString().includes(val))
        );

        card.style.display = (cardNameMatches || dbHasMatch) ? "block" : "none";
    });

    // 2. ÉRMESOROK SZŰRÉSE (Csak ha nem a főmenüben vagyunk)
    if (!isMainMenu) {
        const rows = document.querySelectorAll('.year-row');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? "flex" : "none";
        });

        // 3. CSOPORTFEJLÉCEK (pl. "5 Ft") elrejtése/megnyitása
        document.querySelectorAll('.coin-group').forEach(group => {
            const hasVisibleRow = Array.from(group.querySelectorAll('.year-row'))
                                       .some(r => r.style.display !== "none");
            
            group.style.display = hasVisibleRow ? "block" : "none";
            
            if (val !== "" && hasVisibleRow) {
                const list = group.querySelector('.year-list');
                const header = group.querySelector('.group-header');
                if (list) list.style.display = "block";
                if (header) header.classList.add('open');
            }
        });
    }
}

    // EZ HIÁNYZOTT: A lenyitásért felelős függvény
    function toggleGroup(id) {
        const list = document.getElementById('list-' + id);
        const header = document.querySelector(`#group-${id} .group-header`);
        const isOpen = list.style.display === 'block';
        
        list.style.display = isOpen ? 'none' : 'block';
        header.classList.toggle('open', !isOpen);
    }

    // EZ HIÁNYZOTT: Az érme állapotát mentő függvény
    function updateCoin(groupId, year, isChecked) {
        localStorage.setItem(`coin-${groupId}-${year}`, isChecked);
        const row = document.getElementById(`row-${groupId}-${year}`);
        if(row) row.classList.toggle('is-collected', isChecked);
        refreshStats();
    }

    // EZ HIÁNYZOTT: A kép nagyítása
    function zoomImg(src, event) {
        event.stopPropagation();
        const overlay = document.getElementById('image-overlay');
        const zoomedImg = document.getElementById('zoomed-img');
        zoomedImg.src = src;
        overlay.style.display = 'flex';
    }

    function showMenu() {
    const container = document.getElementById('catalog-container');
    delete container.dataset.activeCat;
    
    // Kereső ürítése és minden kártya mutatása
    document.getElementById('coin-search').value = '';
    filterCoins(); 

    document.getElementById('main-menu').style.display = 'block';
    document.getElementById('catalog-view').style.display = 'none';
    refreshStats();
}

    function refreshStats() {
        const container = document.getElementById('catalog-container');
        const activeCatId = container.dataset.activeCat || null;

        let totalAll = 0;
        let collectedAll = 0;

        Object.keys(databases).forEach(catId => {
            if (activeCatId && catId !== activeCatId) return;

            databases[catId].forEach(group => {
                group.years.forEach(year => {
                    totalAll++;
                    if (localStorage.getItem(`coin-${group.id}-${year.y}`) === 'true') {
                        collectedAll++;
                    }
                });
            });
        });

        if(document.getElementById('total-count')) {
            document.getElementById('total-count').innerText = totalAll;
            document.getElementById('collected-count').innerText = collectedAll;
            document.getElementById('percent').innerText = totalAll > 0 ? Math.round((collectedAll / totalAll) * 100) + "%" : "0%";
        }

        const groups = document.querySelectorAll('.coin-group');
        groups.forEach(group => {
            const groupId = group.id.replace('group-', '');
            const checkboxes = group.querySelectorAll('input[type="checkbox"]');
            const total = checkboxes.length;
            const checked = group.querySelectorAll('input[type="checkbox"]:checked').length;
            const percent = total > 0 ? Math.round((checked / total) * 100) : 0;
            
            const progLabel = document.getElementById(`prog-${groupId}`);
            if (progLabel) {
                progLabel.innerText = `${checked}/${total}`;
                progLabel.style.background = (total === checked && total > 0) ? "#4CAF50" : "#555";
            }

            const percLabel = document.getElementById(`perc-${groupId}`);
            if (percLabel) {
                percLabel.innerText = `${percent}%`;
            }
        });
    }

 window.onload = refreshStats;
</script>
</body>
</html>
